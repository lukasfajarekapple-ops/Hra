<!DOCTYPE html>
<html lang="cs">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Autopilot — vesmírná střílečka</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@600;800&display=swap');
  *{box-sizing:border-box; -webkit-tap-highlight-color:transparent;}
  html,body{ margin:0; height:100%; overflow:hidden; background:#000; font-family:'Orbitron',sans-serif; }
  #app{ position:fixed; inset:0; }
  canvas{ display:block; }
  #hud{
    position:fixed; top:16px; left:16px; color:#8ff0ff; font-size:14px;
    letter-spacing:2px; text-shadow:0 0 10px rgba(80,220,255,0.7);
    opacity:0.85; transition:opacity 1s ease; pointer-events:none;
  }
  #hud .big{ font-size:26px; font-weight:800; display:block; }
</style>
</head>
<body>
<div id="app"></div>
<div id="hud"><span class="big" id="score">0</span>SESTŘELENO</div>

<script src="https://unpkg.com/three@0.121.1/build/three.min.js"></script>
<script>
(function(){
  const app = document.getElementById('app');

  // ================= SCENE =================
  const scene = new THREE.Scene();
  scene.background = new THREE.Color(0x02030a);
  scene.fog = new THREE.FogExp2(0x02030a, 0.018);

  const camera = new THREE.PerspectiveCamera(58, innerWidth/innerHeight, 0.1, 500);
  camera.position.set(0, 6, 16);

  const renderer = new THREE.WebGLRenderer({ antialias:true });
  renderer.setPixelRatio(Math.min(2, devicePixelRatio));
  renderer.setSize(innerWidth, innerHeight);
  renderer.toneMapping = THREE.ACESFilmicToneMapping;
  renderer.toneMappingExposure = 1.3;
  app.appendChild(renderer.domElement);
  addEventListener('resize', function(){
    camera.aspect = innerWidth/innerHeight; camera.updateProjectionMatrix();
    renderer.setSize(innerWidth, innerHeight);
  });

  scene.add(new THREE.AmbientLight(0x223355, 1.2));
  const key = new THREE.PointLight(0x66ccff, 2.2, 40);
  key.position.set(0,8,4); scene.add(key);

  // ================= GLOW SPRITE HELPER =================
  function glowTexture(color){
    const c = document.createElement('canvas'); c.width=128; c.height=128;
    const ctx = c.getContext('2d');
    const g = ctx.createRadialGradient(64,64,0,64,64,64);
    g.addColorStop(0, color); g.addColorStop(1,'rgba(0,0,0,0)');
    ctx.fillStyle=g; ctx.fillRect(0,0,128,128);
    return new THREE.CanvasTexture(c);
  }
  const glowCyan = glowTexture('rgba(140,240,255,1)');
  const glowOrange = glowTexture('rgba(255,170,90,1)');
  const glowRed = glowTexture('rgba(255,90,90,1)');
  const glowWhite = glowTexture('rgba(255,255,255,1)');
  function makeGlowSprite(tex, size, opacity){
    const mat = new THREE.SpriteMaterial({ map:tex, blending:THREE.AdditiveBlending, transparent:true, depthWrite:false, opacity: opacity===undefined?1:opacity });
    const s = new THREE.Sprite(mat); s.scale.set(size,size,1); return s;
  }

  // ================= STARFIELD =================
  const starGeo = new THREE.BufferGeometry();
  const STAR_COUNT = 2200;
  const starPos = new Float32Array(STAR_COUNT*3);
  for(let i=0;i<STAR_COUNT;i++){
    const r = 60+Math.random()*180;
    const th = Math.random()*Math.PI*2, ph = Math.acos(Math.random()*2-1);
    starPos[i*3]   = r*Math.sin(ph)*Math.cos(th);
    starPos[i*3+1] = r*Math.cos(ph);
    starPos[i*3+2] = r*Math.sin(ph)*Math.sin(th);
  }
  starGeo.setAttribute('position', new THREE.BufferAttribute(starPos,3));
  const starMat = new THREE.PointsMaterial({ color:0xffffff, size:0.5, sizeAttenuation:true, transparent:true, opacity:0.85 });
  scene.add(new THREE.Points(starGeo, starMat));

  // distant nebula blobs
  const nebulaTex1 = glowTexture('rgba(120,80,220,0.7)');
  const nebulaTex2 = glowTexture('rgba(60,160,220,0.6)');
  for(let i=0;i<5;i++){
    const s = makeGlowSprite(i%2?nebulaTex1:nebulaTex2, 60+Math.random()*40, 0.35);
    s.position.set((Math.random()-0.5)*140, (Math.random()-0.5)*60, -80-Math.random()*60);
    scene.add(s);
  }

  // ================= ARENA GROUND GRID (subtle) =================
  const grid = new THREE.GridHelper(80, 40, 0x224466, 0x112233);
  grid.position.y = -6;
  grid.material.transparent = true; grid.material.opacity = 0.25;
  scene.add(grid);

  // ================= PLAYER SHIP =================
  const player = new THREE.Group();
  const bodyMat = new THREE.MeshStandardMaterial({ color:0x1a2a3a, emissive:0x0a1420, metalness:0.6, roughness:0.35 });
  const accentMat = new THREE.MeshStandardMaterial({ color:0x2a4a6a, emissive:0x2288ff, emissiveIntensity:0.6, metalness:0.4, roughness:0.3 });

  const hull = new THREE.Mesh(new THREE.ConeGeometry(0.55,2.4,8), bodyMat);
  hull.rotation.x = Math.PI/2; player.add(hull);
  const wingGeo = new THREE.BoxGeometry(2.2,0.08,0.7);
  const wing = new THREE.Mesh(wingGeo, accentMat);
  wing.position.set(0,-0.05,0.2); player.add(wing);
  const finL = new THREE.Mesh(new THREE.BoxGeometry(0.08,0.4,0.5), accentMat);
  finL.position.set(-1.0,0.15,0.4); player.add(finL);
  const finR = finL.clone(); finR.position.x=1.0; player.add(finR);

  const engineGlow = makeGlowSprite(glowCyan, 1.6);
  engineGlow.position.set(0,0,1.3); player.add(engineGlow);
  const engineLight = new THREE.PointLight(0x66ccff, 1.6, 6);
  engineLight.position.set(0,0,1.2); player.add(engineLight);

  scene.add(player);
  player.position.set(0,0,0);

  // ================= ENEMIES =================
  const enemies = [];
  const enemyGeo = new THREE.OctahedronGeometry(0.55,0);
  function spawnEnemy(){
    const mat = new THREE.MeshStandardMaterial({ color:0x3a1010, emissive:0xff3344, emissiveIntensity:0.9, metalness:0.3, roughness:0.4 });
    const mesh = new THREE.Mesh(enemyGeo, mat);
    const ang = Math.random()*Math.PI*2;
    const r = 22+Math.random()*8;
    mesh.position.set(Math.cos(ang)*r, (Math.random()-0.5)*8, Math.sin(ang)*r - 10);
    const glow = makeGlowSprite(glowRed, 1.4, 0.8);
    mesh.add(glow);
    mesh.userData = { alive:true, wobble:Math.random()*10, speed:0.6+Math.random()*0.5, driftPhase:Math.random()*Math.PI*2 };
    scene.add(mesh);
    enemies.push(mesh);
  }
  for(let i=0;i<6;i++) spawnEnemy();

  // ================= LASERS =================
  const lasers = [];
  const laserGeo = new THREE.CylinderGeometry(0.03,0.03,1,6);
  function fireLaserAt(targetPos){
    const from = player.position.clone().add(new THREE.Vector3(0,0,1.1).applyQuaternion(player.quaternion));
    const dir = targetPos.clone().sub(from);
    const dist = dir.length();
    dir.normalize();
    const mat = new THREE.MeshBasicMaterial({ color:0x8ff0ff });
    const mesh = new THREE.Mesh(laserGeo, mat);
    mesh.scale.y = 1.4;
    mesh.position.copy(from);
    mesh.quaternion.setFromUnitVectors(new THREE.Vector3(0,1,0), dir);
    const tip = makeGlowSprite(glowCyan, 0.6);
    mesh.add(tip); tip.position.y = 0.7;
    scene.add(mesh);
    lasers.push({ mesh, from:from.clone(), dir, dist, traveled:0, speed:60, target:targetPos.clone() });
  }

  // ================= EXPLOSIONS =================
  const explosions = [];
  function spawnExplosion(pos, color){
    const tex = color==='orange'?glowOrange:glowWhite;
    const group = [];
    for(let i=0;i<10;i++){
      const s = makeGlowSprite(i%2?glowRed:glowOrange, 0.9+Math.random()*0.6);
      s.position.copy(pos);
      const dir = new THREE.Vector3((Math.random()-0.5),(Math.random()-0.5),(Math.random()-0.5)).normalize();
      s.userData = { vel: dir.multiplyScalar(3+Math.random()*4), life:1 };
      scene.add(s); group.push(s);
    }
    const flash = new THREE.PointLight(0xffaa66, 4, 10);
    flash.position.copy(pos); scene.add(flash);
    explosions.push({ sprites:group, flash, life:1 });
  }

  // ================= HUD =================
  let score = 0;
  const scoreEl = document.getElementById('score');
  function addScore(){ score++; scoreEl.textContent = score; }

  // ================= PLAYER AUTOPILOT =================
  let t = 0;
  let fireTimer = 0;
  let currentTarget = null;
  let retargetTimer = 0;

  function updatePlayer(dt){
    // smooth patrol path (Lissajous-like) so it always looks intentional, not random
    const speed = 0.28;
    const px = Math.sin(t*speed)*9 + Math.sin(t*speed*0.6)*3;
    const py = Math.sin(t*speed*0.8)*2.5 + 1;
    const pz = Math.cos(t*speed*0.7)*7;
    const prev = player.position.clone();
    player.position.set(px,py,pz);

    const vel = player.position.clone().sub(prev);
    if(vel.lengthSq()>0.00001){
      const lookTarget = player.position.clone().add(vel.clone().normalize());
      const m = new THREE.Matrix4().lookAt(player.position, lookTarget, new THREE.Vector3(0,1,0));
      const q = new THREE.Quaternion().setFromRotationMatrix(m);
      player.quaternion.slerp(q, 0.15);
      // bank into turns
      player.rotation.z = THREE.MathUtils.lerp(player.rotation.z, -vel.x*4, 0.1);
    }

    // camera follows cinematically behind/above
    const camTarget = player.position.clone().add(new THREE.Vector3(0,3.2,9).applyQuaternion(new THREE.Quaternion()));
    camera.position.lerp(new THREE.Vector3(player.position.x*0.6, 5+Math.sin(t*0.1)*1, 14+Math.sin(t*0.05)*3), 0.02);
    camera.lookAt(player.position.x*0.3, player.position.y*0.5, player.position.z*0.3 - 4);

    engineLight.intensity = 1.3 + Math.sin(t*20)*0.3;
    engineGlow.scale.setScalar(1.5+Math.sin(t*25)*0.15);
  }

  function updateTargeting(dt){
    retargetTimer -= dt;
    if(!currentTarget || !currentTarget.userData.alive || retargetTimer<=0){
      retargetTimer = 0.4;
      let best=null, bestDist=Infinity;
      enemies.forEach(function(e){
        if(!e.userData.alive) return;
        const d = e.position.distanceTo(player.position);
        if(d<bestDist){ bestDist=d; best=e; }
      });
      currentTarget = best;
    }
    fireTimer -= dt;
    if(currentTarget && currentTarget.userData.alive && fireTimer<=0){
      fireTimer = 0.35 + Math.random()*0.2;
      fireLaserAt(currentTarget.position.clone());
    }
  }

  function updateEnemies(dt){
    enemies.forEach(function(e){
      if(!e.userData.alive) return;
      e.userData.driftPhase += dt*e.userData.speed;
      const toCenter = new THREE.Vector3(0,0,-4).sub(e.position).normalize();
      e.position.addScaledVector(toCenter, dt*1.1);
      e.position.y += Math.sin(e.userData.driftPhase)*dt*1.2;
      e.rotation.x += dt*0.6; e.rotation.y += dt*0.8;
      if(e.position.distanceTo(player.position) < 1.4 && e.userData.alive){
        // graze -> gentle bounce away, purely cosmetic (no player damage, this is a background visual)
        const away = e.position.clone().sub(player.position).normalize();
        e.position.addScaledVector(away, dt*4);
      }
    });
  }

  function updateLasers(dt){
    for(let i=lasers.length-1;i>=0;i--){
      const l = lasers[i];
      l.traveled += l.speed*dt;
      l.mesh.position.copy(l.from).addScaledVector(l.dir, l.traveled);
      if(l.traveled >= l.dist){
        scene.remove(l.mesh);
        lasers.splice(i,1);
        if(currentTarget && currentTarget.position.distanceTo(l.target) < 2 && currentTarget.userData.alive){
          currentTarget.userData.alive = false;
          spawnExplosion(currentTarget.position.clone());
          scene.remove(currentTarget);
          const idx = enemies.indexOf(currentTarget);
          if(idx>=0) enemies.splice(idx,1);
          addScore();
          currentTarget = null;
          setTimeout(spawnEnemy, 300+Math.random()*500);
        }
      }
    }
  }

  function updateExplosions(dt){
    for(let i=explosions.length-1;i>=0;i--){
      const ex = explosions[i];
      ex.life -= dt*1.2;
      ex.flash.intensity = Math.max(0, ex.life*4);
      ex.sprites.forEach(function(s){
        s.position.addScaledVector(s.userData.vel, dt);
        s.userData.vel.multiplyScalar(0.94);
        s.material.opacity = Math.max(0, ex.life);
        s.scale.multiplyScalar(1+dt*0.6);
      });
      if(ex.life<=0){
        scene.remove(ex.flash);
        ex.sprites.forEach(function(s){ scene.remove(s); });
        explosions.splice(i,1);
      }
    }
  }

  // ================= LOOP =================
  const clock = new THREE.Clock();
  function loop(){
    const dt = Math.min(0.05, clock.getDelta());
    t += dt;
    updatePlayer(dt);
    updateTargeting(dt);
    updateEnemies(dt);
    updateLasers(dt);
    updateExplosions(dt);
    while(enemies.filter(function(e){return e.userData.alive;}).length < 5){ spawnEnemy(); }
    renderer.render(scene, camera);
    requestAnimationFrame(loop);
  }
  loop();
})();
</script>
</body>
</html>
